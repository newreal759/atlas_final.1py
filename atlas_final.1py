# ========================== AUTO-INSTALL & DEPENDENCY RESOLVE ==========================
def bootstrap():
    deps = [
        ("python-dotenv", "dotenv"),
        ("httpx[http2]", "httpx"),
        ("orjson", "orjson"),
        ("uvloop", "uvloop"),
        ("websockets", "websockets"),
    ]
    for pip_name, imp_name in deps:
        try:
            __import__(imp_name)
        except ImportError:
            subprocess.check_call([sys.executable, "-m", "pip", "install", "-q", pip_name])

bootstrap()

